# Copy to deploy/app.env and fill in. This file is git-ignored.
# Loaded by the API systemd unit via EnvironmentFile.

# Public port your Mikrus exposes for this app (use your assigned port).
PORT=8000

# Editor login code (required) — the secret typed on the /login page.
EDIT_SECRET=change-me

# Cookie signing key (required) — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-too

# SQLite file path. Relative paths resolve against the repo dir (WorkingDirectory).
DATABASE_PATH=./songs.db

# Ensure Polish characters render correctly in logs.
PYTHONIOENCODING=utf-8
